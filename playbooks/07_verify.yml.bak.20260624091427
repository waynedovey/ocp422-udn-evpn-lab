---
- name: Verify FRR, BGP EVPN and OpenShift UDN objects
  hosts: all
  become: true
  gather_facts: false
  tasks:
    - name: OpenShift object status
      become: false
      ansible.builtin.shell: |
        set -euo pipefail
        export PATH={{ installer_bin_dir }}:$PATH
        export KUBECONFIG={{ kubeconfig_path }}
        echo "# Nodes"
        oc get nodes -o wide
        echo
        echo "# FRR-K8s pods"
        oc -n openshift-frr-k8s get pods -o wide || true
        echo
        echo "# VTEP"
        oc get vtep -o wide || true
        echo
        echo "# RouteAdvertisements"
        oc get routeadvertisements -o yaml || true
        echo
        echo "# CUDN"
        oc get clusteruserdefinednetwork {{ cudn_name }} -o yaml || true
        echo
        echo "# Test pods"
        oc -n {{ cudn_namespace }} get pods -o wide || true
      register: oc_status
      changed_when: false


    - name: Cluster access status
      become: false
      ansible.builtin.shell: |
        set -euo pipefail
        export PATH={{ installer_bin_dir }}:$PATH
        export KUBECONFIG={{ kubeconfig_path }}

        echo "# Cluster access"
        echo "Console URL:"
        oc -n openshift-console get route console -o jsonpath='https://{.spec.host}{"\n"}' || true
        echo
        echo "Username:"
        echo "kubeadmin"
        echo
{% if show_kubeadmin_password | default(false) | bool %}
        echo "Password:"
        if [ -f "{{ install_dir }}/auth/kubeadmin-password" ]; then
          cat "{{ install_dir }}/auth/kubeadmin-password"
          echo
        else
          oc -n kube-system get secret kubeadmin -o jsonpath="{.data.kubeadmin}" | base64 -d
          echo
        fi
{% else %}
        echo "Password:"
        echo "hidden - run: make verify SITE={{ site_id }} SHOW_KUBEADMIN_PASSWORD=true"
{% endif %}
      register: cluster_access_status
      changed_when: false

    - name: Bastion FRR status
      ansible.builtin.shell: |
        set -euo pipefail
        echo "# FRR service"
        systemctl --no-pager --full status frr | sed -n '1,25p' || true
        echo
        echo "# BGP summary"
        vtysh -c 'show bgp summary' || true
        echo
        echo "# EVPN summary"
        vtysh -c 'show bgp l2vpn evpn summary' || true
        echo
        echo "# EVPN routes"
        vtysh -c 'show bgp l2vpn evpn' || true
        echo
        echo "# Local VNI devices"
        ip -d link show vxlan{{ evpn_mac_vrf_vni }} || true
        bridge fdb show dev vxlan{{ evpn_mac_vrf_vni }} || true
      register: frr_status
      changed_when: false


    - name: Print cluster access status
      ansible.builtin.debug:
        msg: "{{ cluster_access_status.stdout }}"

    - name: Print OpenShift status
      ansible.builtin.debug:
        msg: "{{ oc_status.stdout }}"

    - name: Print FRR status
      ansible.builtin.debug:
        msg: "{{ frr_status.stdout }}"
